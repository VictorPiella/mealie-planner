# ─────────────────────────────────────────────────────────────────
# Mealie Planner — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# Full URL of your Mealie instance (no trailing slash)
VITE_MEALIE_URL=https://mealie.example.com

# Long-lived API token (see README → "Getting a Mealie API Token")
# Without this the app shows built-in sample recipes instead.
VITE_MEALIE_TOKEN=
